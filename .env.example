
# Hugging Face token (optional, for faster model downloads)
HF_TOKEN=hf_your_token_here

# LLM backend: "llama_cpp", "anthropic", or "openai"
LLM_BACKEND=llama_cpp

# Path to local GGUF model (required for llama_cpp backend)
# Supports %USERPROFILE% and other env vars for portability
LLAMA_CPP_MODEL_PATH=
# API keys for cloud backends (only needed if LLM_BACKEND=anthropic or openai)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx

# --- RAG Config (all optional — sensible defaults below) ---

# Bi-encoder retrieval
RAG_TOP_K=5
RAG_MIN_RELEVANCE=0.3
RAG_N_CANDIDATES=50

# Query expansion (glossary synonyms)
RAG_EXPANSION_ENABLED=true
RAG_EXPANSION_N_TERMS=3

# Cross-encoder re-ranking
RAG_CROSS_ENCODER_ENABLED=true
RAG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_CROSS_ENCODER_DEVICE=cpu
RAG_CROSS_ENCODER_BATCH_SIZE=32
RAG_CROSS_ENCODER_WEIGHT=0.7

# Forward-looking statement penalty
RAG_FORWARD_LOOKING_PENALTY_ENABLED=true
RAG_FORWARD_LOOKING_PENALTY_WEIGHT=-0.15

# Keyword boosting (works alongside cross-encoder)
RAG_KEYWORD_BOOST_ENABLED=true
RAG_KEYWORD_BOOST_WEIGHT=0.15

# LLM generation
RAG_LLM_MAX_TOKENS=2048
RAG_LLM_TEMPERATURE=0.1
